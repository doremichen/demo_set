<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <import type="com.adam.app.demoset.sysmonitor.util.DateUtils" />
        <variable
            name="viewModel"
            type="com.adam.app.demoset.sysmonitor.viewmodel.SysMonitorViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:background="?android:attr/colorBackground">

        <androidx.core.widget.NestedScrollView
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tv_header"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="?android:attr/textColorPrimary"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/tv_description"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/sys_monitor_description"
                    android:textSize="14sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:lineSpacingExtra="4dp"
                    app:layout_constraintTop_toBottomOf="@id/tv_header"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Battery Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_battery"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:layout_constraintTop_toBottomOf="@id/tv_description"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/battery_label"
                            android:textStyle="bold"
                            android:textAllCaps="true"
                            android:letterSpacing="0.1"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_battery_val"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text='@{viewModel.systemStatus.batteryLevel >= 0 ? viewModel.systemStatus.batteryLevel + "%" : "--"}'
                            android:textSize="32sp"
                            android:textColor="?android:attr/textColorPrimary"
                            android:textStyle="bold" />

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            app:trackCornerRadius="4dp"
                            android:progress="@{viewModel.systemStatus.batteryLevel}" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Storage Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_storage"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:layout_constraintTop_toBottomOf="@id/card_battery"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/storage_label"
                            android:textStyle="bold"
                            android:textAllCaps="true"
                            android:letterSpacing="0.1"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_storage_val"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@{viewModel.systemStatus.storageUsage}"
                            android:textSize="20sp"
                            android:textColor="?android:attr/textColorPrimary" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Memory Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_memory"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:layout_constraintTop_toBottomOf="@id/card_storage"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/memory_label"
                            android:textStyle="bold"
                            android:textAllCaps="true"
                            android:letterSpacing="0.1"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_memory_val"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@{viewModel.systemStatus.memoryUsage}"
                            android:textSize="20sp"
                            android:textColor="?android:attr/textColorPrimary" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tv_footer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="24dp"
                    android:text="@{@string/last_update + ' ' + DateUtils.formatTimestamp(viewModel.systemStatus.timestamp)}"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorSecondary"
                    app:layout_constraintTop_toBottomOf="@id/card_memory"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
