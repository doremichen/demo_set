<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <import type="android.view.View" />
        <variable
            name="viewModel"
            type="com.adam.app.demoset.jobService.viewmodel.DemoJobSvrViewModel" />
    </data>

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/root_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:title="@string/bg_exec_title"
                app:titleCentered="true" />

        </com.google.android.material.appbar.AppBarLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <!-- Header -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/header_card"
                    style="@style/Widget.Material3.CardView.Elevated"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/bg_exec_title"
                            android:textAppearance="?attr/textAppearanceTitleLarge"
                            android:textColor="?attr/colorPrimary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/bg_exec_desc"
                            android:textAppearance="?attr/textAppearanceBodyMedium" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Job Type / Mode Selection -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/mode_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="12dp"
                    app:contentPadding="16dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/header_card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/bg_exec_label_job_type"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="?attr/colorPrimary" />

                        <!-- UI Mode (Legacy vs Modern) -->
                        <com.google.android.material.button.MaterialButtonToggleGroup
                            android:id="@+id/toggle_group_mode"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:gravity="center"
                            app:selectionRequired="true"
                            app:singleSelection="true">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_mode_legacy"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:checkable="true"
                                android:text="@string/bg_exec_mode_legacy" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_mode_modern"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:checkable="true"
                                android:text="@string/bg_exec_mode_modern" />

                        </com.google.android.material.button.MaterialButtonToggleGroup>

                        <!-- Job Sub-Type (Only visible for Modern Job) -->
                        <RadioGroup
                            android:id="@+id/radio_group_job_type"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:visibility="@{viewModel.isModernMode ? View.VISIBLE : View.GONE}">

                            <RadioButton
                                android:id="@+id/radio_job_user_initiated"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checked="true"
                                android:onClick="@{() -> viewModel.setUserInitiated(true)}"
                                android:text="@string/bg_exec_type_user_initiated" />

                            <RadioButton
                                android:id="@+id/radio_job_deferred"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:onClick="@{() -> viewModel.setUserInitiated(false)}"
                                android:text="@string/bg_exec_type_deferred" />
                        </RadioGroup>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Constraints Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/constraints_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:visibility="@{viewModel.isModernMode ? View.VISIBLE : View.GONE}"
                    app:cardCornerRadius="12dp"
                    app:contentPadding="16dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/mode_card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/bg_exec_label_constraints"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="?attr/colorPrimary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/bg_exec_label_network"
                            android:textAppearance="?attr/textAppearanceLabelLarge" />

                        <RadioGroup
                            android:id="@+id/radio_group_network"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:checkedButton="@={viewModel.networkTypeId}"
                            android:orientation="horizontal">

                            <RadioButton
                                android:id="@+id/radio_net_any"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/lable_option_any_network" />

                            <RadioButton
                                android:id="@+id/radio_net_unmetered"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="16dp"
                                android:enabled="@{viewModel.isWifiEnabled}"
                                android:text="@string/label_option_wifi_network" />
                        </RadioGroup>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/bg_exec_label_device"
                            android:textAppearance="?attr/textAppearanceLabelLarge" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switch_charging"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:checked="@={viewModel.isChargingRequired}"
                            android:text="@string/label_switch_charging" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switch_idle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:checked="@={viewModel.isIdleRequired}"
                            android:enabled="@{!viewModel.isModernMode || !viewModel.isUserInitiated}"
                            android:text="@string/label_switch_idle" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Status Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/status_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="?attr/colorSurfaceVariant"
                    app:cardCornerRadius="12dp"
                    app:contentPadding="16dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/constraints_card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@{viewModel.statusText}"
                            android:textAppearance="?attr/textAppearanceTitleSmall"
                            tools:text="Status: Idle" />

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progress_indicator"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:progress="@{viewModel.progress}"
                            app:trackThickness="8dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Actions -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_start"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:onClick="@{() -> viewModel.startTask()}"
                    android:text="@string/bg_exec_btn_start"
                    app:icon="@android:drawable/ic_media_play"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/status_card" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_stop"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:onClick="@{() -> viewModel.stopTask()}"
                    android:text="@string/bg_exec_btn_stop"
                    app:icon="@android:drawable/ic_delete"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/btn_start" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</layout>
