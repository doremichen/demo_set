<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">
    <data>
        <variable
            name="vm"
            type="com.adam.app.demoset.camera.viewmodel.CameraXViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/root_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_gradient"
        tools:context=".camera.CameraXActivity">

        <FrameLayout
            android:id="@+id/app_bar_wrapper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginVertical="16dp"
                android:background="@drawable/bg_title_border"
                android:paddingHorizontal="24dp"
                android:paddingVertical="12dp"
                android:text="@string/title_demo_camerax"
                android:textColor="@android:color/white"
                android:textSize="24sp"
                android:textStyle="bold" />
        </FrameLayout>

        <androidx.camera.view.PreviewView
            android:id="@+id/viewFinder"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/app_bar_wrapper"
            app:layout_constraintBottom_toTopOf="@id/layout_actions" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="8dp"
            app:cardBackgroundColor="#80000000"
            app:strokeWidth="0dp"
            app:layout_constraintTop_toTopOf="@id/viewFinder"
            app:layout_constraintStart_toStartOf="@id/viewFinder">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:text='@{vm.statusText}'
                android:textColor="@android:color/white"
                android:textSize="12sp"
                tools:text="Camera State: Ready" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/layout_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCapture"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="@string/action_capture"
                app:cornerRadius="12dp"
                android:onClick="@{() -> vm.performCapture()}" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewPhoto"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:text="@string/action_view_photo"
                android:enabled="@{vm.lastPhotoUri != null}"
                app:cornerRadius="12dp"
                android:onClick="@{() -> vm.triggerViewPhoto()}" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
