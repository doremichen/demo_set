<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="viewModel"
            type="com.adam.app.demoset.usb_storage.viewmodel.UsbViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:padding="16dp">

        <!-- Local Files Header -->
        <TextView
            android:id="@+id/local_path_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@{`Local Path: ` + viewModel.currentLocalPath}"
            android:textColor="#888"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Local Path: /storage/emulated/0" />

        <RelativeLayout
            android:id="@+id/local_title_layout"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginTop="4dp"
            android:background="#26afcc"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/local_path_label">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="@string/title_local_file"
                android:textColor="#ffff"
                android:textSize="16sp" />

            <ImageButton
                android:id="@+id/local_backspace_iv"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="10dp"
                android:background="@drawable/selector_btn_backspace"
                android:contentDescription="@null"
                android:onClick="@{() -> viewModel.navigateUpLocal()}" />
        </RelativeLayout>

        <!-- Local Files List -->
        <ListView
            android:id="@+id/local_file_lv"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:divider="@drawable/shape_line"
            app:layout_constraintBottom_toTopOf="@+id/guideline_horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/local_title_layout"
            app:layout_constraintVertical_weight="1" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline_horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.5" />

        <!-- USB Files Header -->
        <RelativeLayout
            android:id="@+id/usb_title_layout"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginTop="16dp"
            android:background="#26afcc"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/guideline_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="@string/title_usb_file"
                android:textColor="#ffff"
                android:textSize="16sp" />

            <ImageButton
                android:id="@+id/usb_backspace_iv"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="10dp"
                android:background="@drawable/selector_btn_backspace"
                android:contentDescription="@null"
                android:onClick="@{() -> viewModel.navigateUpUsb()}" />
        </RelativeLayout>

        <!-- USB Files List -->
        <ListView
            android:id="@+id/usb_file_lv"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:divider="@drawable/shape_line"
            app:layout_constraintBottom_toTopOf="@+id/controls_layout"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/usb_title_layout"
            app:layout_constraintVertical_weight="1" />

        <!-- Controls -->
        <LinearLayout
            android:id="@+id/controls_layout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintBottom_toTopOf="@+id/show_progress_tv"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/usb_file_lv">

            <Button
                android:id="@+id/refresh_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:onClick="@{() -> viewModel.updateUsbList()}"
                android:text="@string/action_refresh_usb" />

        </LinearLayout>

        <!-- Progress Text -->
        <TextView
            android:id="@+id/show_progress_tv"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@{viewModel.progressText}"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/controls_layout" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
