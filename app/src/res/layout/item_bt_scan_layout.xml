<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <import type="android.bluetooth.BluetoothDevice"/>
        <variable
            name="item"
            type="com.adam.app.demoset.bluetooth.model.BtDeviceItem" />
        <variable
            name="buttonListener"
            type="com.adam.app.demoset.bluetooth.view.BTDeviceListAdapter.OnItemButtonClickListener" />
        <variable
            name="nameListener"
            type="com.adam.app.demoset.bluetooth.view.BTDeviceListAdapter.OnItemNameClickListener" />
        <variable
            name="position"
            type="Integer" />
    </data>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginVertical="6dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="?attr/colorOutlineVariant"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <ImageView
                android:id="@+id/iv_bt_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_bluetooth"
                app:tint="?attr/colorPrimary"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@+id/tv_bt_name"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tv_bt_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:ellipsize="marquee"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:fontFamily="@font/cabin_bold"
                android:marqueeRepeatLimit="marquee_forever"
                android:singleLine="true"
                android:text="@{item.device.name}"
                android:textColor="?attr/colorOnSurface"
                android:textSize="18sp"
                android:textStyle="bold"
                android:onClick="@{() -> nameListener.onClick(position)}"
                app:layout_constraintEnd_toStartOf="@+id/btn_bt_pair"
                app:layout_constraintStart_toEndOf="@id/iv_bt_icon"
                app:layout_constraintTop_toTopOf="parent" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tv_bt_address"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/cabin_bold"
                android:text="@{item.connected ? @string/demo_bt_connect : item.device.address}"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="@+id/tv_bt_name"
                app:layout_constraintStart_toStartOf="@+id/tv_bt_name"
                app:layout_constraintTop_toBottomOf="@+id/tv_bt_name" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_bt_pair"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="100dp"
                android:fontFamily="@font/cabin_bold"
                android:text="@{item.device.bondState == BluetoothDevice.BOND_BONDED ? @string/demo_bt_unpair : @string/demo_bt_pair}"
                android:textAllCaps="false"
                android:textSize="20sp"
                android:onClick="@{() -> buttonListener.onClick(position)}"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>
</layout>
